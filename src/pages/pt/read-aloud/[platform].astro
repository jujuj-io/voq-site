---
import { getCollection } from 'astro:content';
import ReadAloudPlatformPage from '../../../components/ReadAloudPlatformPage.astro';

export async function getStaticPaths() {
  const platforms = await getCollection('platforms', ({ id }) => id.startsWith('pt/'));
  return platforms.map((entry) => ({
    params: { platform: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---
<ReadAloudPlatformPage lang="pt" entry={entry} />
