---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
}

const { title, description, pubDate } = Astro.props;

const formatted = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={`${title} — Voq Blog`} description={description}>
  <div class="container">
    <article class="prose">
      <h1>{title}</h1>
      <p class="meta">{formatted}</p>
      <slot />
    </article>
  </div>
</Base>
