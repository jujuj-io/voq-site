---
import Base from '../layouts/Base.astro';
import pricingData from '../i18n/pages/pricing.json';

interface Props { lang?: string }
const { lang = 'en' } = Astro.props;
const t = pricingData[lang] ?? pricingData.en;
---

<Base title={t.title} description={t.description} lang={lang} path="/pricing">
<div class="container">
<main class="pricing-page">

  <section class="hero">
    <span class="eyebrow">{t.eyebrow}</span>
    <h1>{t.h1_before}<br/>{t.h1_break}<em>{t.h1_em}</em>{t.h1_after}</h1>
    <p class="sub">{t.sub}</p>
  </section>

  <section class="tiers">
    <div class="tier">
      <span class="tag">{t.freeTag}</span>
      <h2>$0<span>/mo</span></h2>
      <p class="who">{t.freeWho}</p>
    </div>
    <div class="tier featured">
      <span class="tag">{t.foundingTag}</span>
      <h2>$2<span>/mo</span></h2>
      <p class="who">{t.foundingWho}</p>
    </div>
  </section>

  <p class="lockin">{t.lockin}</p>

  <section class="whatyoget">
    <h2>{t.whatH2}</h2>
    <div class="grid">
      {t.cards.map((c) => (
        <div class="card">
          <h3>{c.title}</h3>
          <p>{c.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="noaccounts">
    <h2>{t.noaccountsH2}</h2>
    <p>{t.noaccountsP1}</p>
    <p>{t.noaccountsP2}</p>
    <p class="tiny">{t.noaccountsTiny}</p>
  </section>

  <section class="cta">
    <h2>{t.ctaH2}</h2>
    <p>{t.ctaP}</p>
    <a
      class="install-btn"
      href="https://chrome.google.com/webstore/detail/ckkihjnakpnccnmdipbdibeaibigjjde"
      target="_blank"
      rel="noopener"
    >{t.ctaBtn}</a>
  </section>

</main>
</div>
</Base>

<style>
  .pricing-page {
    max-width: 880px;
    margin: 0 auto;
    padding: 64px 24px 96px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color: #0a0a0a;
  }

  .hero { text-align: center; margin-bottom: 56px; }
  .eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6b6b6b;
    background: #f4f4f4;
    padding: 6px 12px;
    border-radius: 999px;
    margin-bottom: 20px;
  }
  .hero h1 {
    font-size: clamp(32px, 5vw, 48px);
    line-height: 1.15;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 18px;
  }
  .hero h1 em { font-style: normal; color: #7c3aed; }
  .hero .sub {
    font-size: 17px;
    line-height: 1.6;
    color: #4b4b4b;
    max-width: 560px;
    margin: 0 auto;
  }

  .tiers {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    max-width: 520px;
    margin: 0 auto 20px;
  }
  .tier {
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    padding: 28px 20px;
    text-align: center;
    background: #fff;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .tier:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
  .tier.featured {
    border-color: #7c3aed;
    box-shadow: 0 4px 20px rgba(124,58,237,0.12);
  }
  .tier .tag {
    display: block;
    font-size: 10.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #7c3aed;
    margin-bottom: 10px;
  }
  .tier h2 {
    font-size: 34px;
    font-weight: 800;
    margin: 0 0 6px;
  }
  .tier h2 span { font-size: 15px; font-weight: 600; color: #999; }
  .tier .who { font-size: 13px; color: #666; margin: 0; }

  .lockin {
    text-align: center;
    font-size: 14px;
    color: #555;
    max-width: 560px;
    margin: 0 auto 72px;
    line-height: 1.6;
  }

  .whatyoget { margin-bottom: 72px; }
  .whatyoget h2, .noaccounts h2, .cta h2 {
    font-size: 26px;
    font-weight: 800;
    text-align: center;
    margin: 0 0 32px;
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .card {
    background: #fafafa;
    border: 1px solid #ececec;
    border-radius: 16px;
    padding: 24px;
  }
  .card h3 { font-size: 16px; font-weight: 700; margin: 0 0 8px; }
  .card p { font-size: 14px; line-height: 1.6; color: #555; margin: 0; }

  .noaccounts {
    background: #f8f7ff;
    border-radius: 20px;
    padding: 40px 32px;
    margin-bottom: 72px;
  }
  .noaccounts p {
    font-size: 15px;
    line-height: 1.7;
    color: #333;
    max-width: 620px;
    margin: 0 auto 16px;
  }
  .noaccounts .tiny { font-size: 12.5px; color: #888; text-align: center; }

  .cta { text-align: center; }
  .cta p { font-size: 15px; color: #555; max-width: 460px; margin: 0 auto 24px; }
  .install-btn {
    display: inline-block;
    background: #0a0a0a;
    color: #fff;
    font-weight: 700;
    font-size: 15px;
    padding: 14px 28px;
    border-radius: 999px;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .install-btn:hover { opacity: 0.85; }

  @media (max-width: 720px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
